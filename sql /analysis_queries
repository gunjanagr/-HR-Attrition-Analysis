query1 = """
SELECT Department,
       COUNT(*) as Total,
       SUM(Attrition_Flag) as Left,
       ROUND(SUM(Attrition_Flag)*100.0/COUNT(*), 2) as Attrition_Rate
FROM hr
GROUP BY Department
ORDER BY Attrition_Rate DESC
"""
